# Copy this file to .env and fill in your own values.

# Port the server runs on
PORT=3000

# Secret key to view submitted messages at /admin.html?key=YOUR_KEY
# Change this to something only you know before deploying.
ADMIN_KEY=myportfolio2003secret

# --- Optional: email notifications for new contact-form messages ---
# If left blank, messages are still saved to data/messages.json,
# just no email will be sent. Works with Gmail, Outlook, SendGrid SMTP, etc.
SMTP_HOST=vaneetpathania01@gmail.com
SMTP_PORT=587
SMTP_USER=vaneetpathania01@gmail.com
SMTP_PASS=your-app-password
NOTIFY_TO=vaneetpathania01@gmail.com
